<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- AI 设置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_settings_section"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/api_url"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <EditText
                android:id="@+id/et_api_url"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="https://api.deepseek.com/v1/chat/completions"
                android:textColor="@color/text_primary"
                android:textColorHint="#44FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_edit_text"
                android:paddingHorizontal="12dp"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/api_key"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="@string/api_key_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="#44FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_edit_text"
                android:paddingHorizontal="12dp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/model_name"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <EditText
                android:id="@+id/et_model"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="deepseek-chat"
                android:textColor="@color/text_primary"
                android:textColorHint="#44FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_edit_text"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/system_prompt"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <EditText
                android:id="@+id/et_system_prompt"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="@string/system_prompt_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="#44FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_edit_text"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:gravity="top" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btn_test_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/test_connection"
                    android:textColor="@color/primary"
                    android:background="@drawable/btn_outline"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btn_save_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/save"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/btn_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- 语音设置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_settings_section"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wake_word"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <EditText
                android:id="@+id/et_wake_word"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="你好氢桌面"
                android:textColor="@color/text_primary"
                android:textColorHint="#44FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_edit_text"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <Switch
                android:id="@+id/switch_voice_wake"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/voice_wake_enabled"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <Switch
                android:id="@+id/switch_tts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tts_enabled"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- 系统设置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/system_settings_section"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <Switch
                android:id="@+id/switch_auto_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_start"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brightness"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <SeekBar
                    android:id="@+id/seek_brightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="255"
                    android:progressTint="@color/primary"
                    android:thumbTint="@color/primary" />
                <TextView
                    android:id="@+id/tv_brightness_value"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/volume"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <SeekBar
                    android:id="@+id/seek_volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="@color/primary"
                    android:thumbTint="@color/primary" />
                <TextView
                    android:id="@+id/tv_volume_value"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- 版本信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/version_info"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
